{
  "apps": [
    {
      "name": "api-template",
      "script": "dist/src/main.js",
      "cwd": "../",
      "instance_var": "INSTANCE_ID",
      "ignore_watch": ["node_modules", "logs", ".pm2"],
      "exec_mode": "cluster",
      "instances": 2,
      "restart_delay": 2000,
      "env_development": {
        "NODE_ENV": "development",
        "watch": false
      },
      "env_production": {
        "NODE_ENV": "production",
        "watch": false
      }
    }
  ]
}
